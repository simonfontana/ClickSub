{
  "manifest_version": 2,
  "name": "ClickSub",
  "version": "1.4.0",
  "description": "Click a word in video subtitles to translate it using DeepL.",
  "permissions": [
    "activeTab",
    "storage",
    "https://api-free.deepl.com/*"
  ],
  "background": {
    "scripts": [
      "utils.js",
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.youtube.com/*",
        "*://www.svtplay.se/*"
      ],
      "js": [
        "utils.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{8bd18a9d-3fe6-4c5c-ba1b-421513d1ad74}",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  },
  "browser_action": {
    "default_title": "ClickSub",
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
